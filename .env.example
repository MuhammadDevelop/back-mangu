# ============================================
# MANGU LIGA BACKEND - Environment Variables
# ============================================
# Bu faylni .env deb nusxalab, o'z qiymatlaringizni kiriting

# Server
PORT=5000

# JWT Secret (murakkab, uzun kalit kiriting)
JWT_SECRET=mangu-liga-v2-super-secret-key-change-this-in-production

# Telegram Bot Token (BotFather'dan oling)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
